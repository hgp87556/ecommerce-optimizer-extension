{
  "manifest_version": 3,
  "name": "E-Commerce Optimizer",
  "version": "1.0.0",
  "description": "Analyze and optimize e-commerce sites with AI-powered recommendations and template generation",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
